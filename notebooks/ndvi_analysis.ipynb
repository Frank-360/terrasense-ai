   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "red = np.random.rand(100,100)\n",
    "nir = np.random.rand(100,100)\n",
    "\n",
    "ndvi = (nir - red)/(nir + red)\n",
    "\n",
    "plt.imshow(ndvi,cmap=\"RdYlGn\")\n",
    "plt.colorbar()\n",
    "plt.title(\"NDVI Vegetation Health\")\n",
    "plt.show()"
   ]
  }
 ],
